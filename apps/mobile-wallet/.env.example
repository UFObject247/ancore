# Ancore Mobile Wallet Environment Variables

# Indexer Service
# REST API endpoint for blockchain data queries and transaction history
EXPO_PUBLIC_INDEXER_URL=http://localhost:3000

# Relayer Service
# HTTP endpoint for transaction relay operations
EXPO_PUBLIC_RELAYER_URL=http://localhost:3001

# AI Agent Service
# HTTP endpoint for natural language intent parsing
EXPO_PUBLIC_AI_AGENT_URL=http://localhost:3002

# WalletConnect
# Project ID from https://cloud.walletconnect.com/
WALLETCONNECT_PROJECT_ID=your_project_id_here

# Environment
# NODE_ENV=development
