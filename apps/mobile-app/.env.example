# Ancore Mobile App Environment Variables

# Required — Soroban account contract for the smart account
ANCORE_ACCOUNT_CONTRACT_ID=your_contract_id_here

# Network (testnet | mainnet | futurenet | local)
ANCORE_MOBILE_NETWORK=testnet

# Indexer Service
ANCORE_INDEXER_URL=http://localhost:3000

# Relayer Service
ANCORE_RELAYER_URL=http://localhost:3001

# WalletConnect
WALLETCONNECT_PROJECT_ID=your_project_id_here

# Environment
NODE_ENV=development
